{
  "name": "speclens",
  "displayName": "SpecLens",
  "icon": "resources/speclens-icon.png",
  "description": "Visual layer for Spec-Driven Development with GitHub Spec Kit. AI-powered spec elaboration, validation, traceability matrix, kanban board, and drift detection.",
  "version": "0.0.6",
  "publisher": "speclens",
  "repository": {
    "type": "git",
    "url": "https://github.com/faizal13/speclens.git"
  },
  "bugs": {
    "url": "https://github.com/faizal13/speclens/issues"
  },
  "homepage": "https://github.com/faizal13/speclens#readme",
  "license": "MIT",
  "engines": { "vscode": ">=1.90.0" },
  "categories": ["Other"],
  "keywords": [
    "spec-driven-development",
    "github-spec-kit",
    "requirements",
    "planning",
    "documentation",
    "ai",
    "copilot",
    "claude",
    "traceability",
    "kanban",
    "validation"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:docs/requirements",
    "workspaceContains:specs"
  ],
  "main": "dist/extension.js",
  "contributes": {
    "commands": [
      {"command": "speclens.elaborateSpec", "title": "SpecLens: 🧠 Elaborate BA Notes → Spec", "category": "SpecLens"},
      {"command": "speclens.generatePlan", "title": "SpecLens: 🏗️ Generate Plan from Spec", "category": "SpecLens"},
      {"command": "speclens.generateTasks", "title": "SpecLens: 📋 Generate Tasks from Plan", "category": "SpecLens"},
      {"command": "speclens.documentBugFix", "title": "SpecLens: 🐛 Document Bug & Create Fix Plan", "category": "SpecLens"},
      {"command": "speclens.createSkill", "title": "SpecLens: 🍒 Create AI Skill from Spec (everything-copilot)", "category": "SpecLens"},
      {"command": "speclens.showValidationReport", "title": "SpecLens: 📊 Show Validation Report", "category": "SpecLens"},
      {"command": "speclens.showTraceabilityMatrix", "title": "SpecLens: 🔗 Show Traceability Matrix", "category": "SpecLens"},
      {"command": "speclens.showKanbanBoard", "title": "SpecLens: 📋 Show Kanban Board", "category": "SpecLens"},
      {"command": "speclens.detectSpecDrift", "title": "SpecLens: 🔍 Detect Spec Drift", "category": "SpecLens"},
      {"command": "speclens.newRequirement", "title": "SpecLens: 📄 New Requirement"},
      {"command": "speclens.newDesign", "title": "SpecLens: 🎨 New Design"},
      {"command": "speclens.newTask", "title": "SpecLens: ✏️ New Task"},
      {"command": "speclens.validateWorkspace", "title": "SpecLens: ✅ Validate Workspace"},
      {"command": "speclens.generateTaskBreakdown", "title": "SpecLens: 🗂️ Generate Task Breakdown"},
      {"command": "speclens.showFlowSummary", "title": "SpecLens: 📈 Show Flow Summary"},
      {"command": "speclens.generateRequirementsDoc", "title": "SpecLens: 📚 Generate Requirements Catalog"},
      {"command": "speclens.generateDesignFromRequirement", "title": "SpecLens: 🎨 Generate Design from Requirement"},
      {"command": "speclens.generateTasksFromDesign", "title": "SpecLens: 📋 Generate Tasks from Design (Interactive)"},
      {"command": "speclens.startTask",       "title": "SpecLens: ▶️ Start Task",          "category": "SpecLens"},
      {"command": "speclens.completeTask",    "title": "SpecLens: ✅ Complete Task",        "category": "SpecLens"},
      {"command": "speclens.blockTask",       "title": "SpecLens: 🚫 Block Task",           "category": "SpecLens"},
      {"command": "speclens.reopenTask",      "title": "SpecLens: 🔄 Reopen Task",          "category": "SpecLens"},
      {"command": "speclens.unblockTask",     "title": "SpecLens: ▶️ Unblock Task",         "category": "SpecLens"},
      {"command": "speclens.executeTask",     "title": "SpecLens: 🤖 Get AI Help on Task",  "category": "SpecLens"},
      {"command": "speclens.viewTaskChanges", "title": "SpecLens: 📝 View Task Changes",    "category": "SpecLens"},
      {"command": "speclens.restartTask",     "title": "SpecLens: 🔁 Restart Task",         "category": "SpecLens"}
    ],
    "configuration": {
      "type": "object",
      "title": "SpecLens Configuration",
      "properties": {
        "speclens.idFormats.requirement": {"type": "string", "default": "^REQ-[0-9]{4}-[0-9]{4}$", "description": "Regex for requirement IDs."},
        "speclens.idFormats.design": {"type": "string", "default": "^DES-[0-9]{4}-[0-9]{4}$", "description": "Regex for design IDs."},
        "speclens.idFormats.task": {"type": "string", "default": "^TASK-[0-9]{4}-[0-9]{4}$", "description": "Regex for task IDs."},
        "speclens.enforceApprovedDesignBeforeTask": {"type": "boolean", "default": true, "description": "Require design approved before creating tasks."},
        "speclens.requiredSections.requirement": {"type": "array", "default": ["problem","metrics"], "items": {"type": "string"}, "description": "Required top-level YAML keys for requirements."},
        "speclens.requiredSections.design": {"type": "array", "default": ["decisions"], "items": {"type": "string"}, "description": "Required top-level YAML keys for designs."},
        "speclens.requiredSections.task": {"type": "array", "default": ["acceptance"], "items": {"type": "string"}, "description": "Required top-level YAML keys for tasks."},
        "speclens.breakdown.includeQualityTasks": {"type": "boolean", "default": true, "description": "Include quality-focused tasks (tests, observability, docs)."},
        "speclens.breakdown.maxTasks": {"type": "number", "default": 40, "description": "Maximum tasks to generate in breakdown preview."},
        "speclens.preferredAgent": {"type": "string", "enum": ["auto", "copilot", "claude", "cursor", "none"], "default": "auto", "description": "Preferred AI agent for task execution (auto = Claude > Copilot > Cursor)"}
      }
    },
    "views": {
      "explorer": [
        {"id": "speclens.view", "name": "SpecLens", "icon": "resources/speclens-icon.svg"}
      ]
    },
    "snippets": [
      { "language": "markdown", "path": "./snippets/requirement.code-snippets" },
      { "language": "markdown", "path": "./snippets/design.code-snippets" },
      { "language": "markdown", "path": "./snippets/task.code-snippets" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "lint": "eslint . --ext .ts",
    "new:req": "node scripts/new.js req",
    "new:design": "node scripts/new.js design",
    "new:task": "node scripts/new.js task",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.4.0",
    "eslint": "^8.56.0",
    "vsce": "2.15.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
